{
  "name": "voice-coding-assistant",
  "displayName": "Voice Coding Assistant",
  "description": "AI-powered voice coding assistant for accessibility — code entirely using voice commands. Supports Indian, American, British, and Australian English accents using Whisper speech recognition and OpenRouter AI.",
  "version": "2.0.0",
  "publisher": "voice-coding",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Machine Learning"
  ],
  "keywords": [
    "voice",
    "coding",
    "accessibility",
    "speech",
    "whisper",
    "ai",
    "hands-free",
    "wake-word",
    "text-to-speech"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "voice-coding-assistant.helloWorld",
        "title": "Voice Coding: Hello World (Test)"
      },
      {
        "command": "voice-coding-assistant.startListening",
        "title": "Voice Coding: Start Listening (Single Command)"
      },
      {
        "command": "voice-coding-assistant.stopListening",
        "title": "Voice Coding: Stop Listening"
      },
      {
        "command": "voice-coding-assistant.typeCommand",
        "title": "Voice Coding: Type Command (Manual)"
      },
      {
        "command": "voice-coding-assistant.startContinuous",
        "title": "Voice Coding: Start Continuous Listening (Hands-Free)"
      },
      {
        "command": "voice-coding-assistant.activateNow",
        "title": "Voice Coding: Activate Now (Skip Wake Word)"
      },
      {
        "command": "voice-coding-assistant.toggleVoiceFeedback",
        "title": "Voice Coding: Toggle Voice Feedback (TTS)"
      }
    ],
    "keybindings": [
      {
        "command": "voice-coding-assistant.startListening",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorFocus"
      },
      {
        "command": "voice-coding-assistant.stopListening",
        "key": "ctrl+shift+x",
        "mac": "cmd+shift+x"
      },
      {
        "command": "voice-coding-assistant.typeCommand",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t"
      },
      {
        "command": "voice-coding-assistant.startContinuous",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      },
      {
        "command": "voice-coding-assistant.activateNow",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      }
    ],
    "configuration": {
      "title": "Voice Coding Assistant",
      "properties": {
        "voiceCodingAssistant.openRouterModel": {
          "type": "string",
          "default": "deepseek/deepseek-chat",
          "enum": [
            "deepseek/deepseek-chat",
            "anthropic/claude-3.5-sonnet",
            "openai/gpt-3.5-turbo",
            "openai/gpt-4o",
            "google/gemini-2.5-flash",
            "meta-llama/llama-3.1-8b-instruct"
          ],
          "enumDescriptions": [
            "DeepSeek Chat — Excellent for code generation, very cost-effective (recommended)",
            "Claude 3.5 Sonnet — Premium code quality, higher cost",
            "GPT-3.5 Turbo — Good balance of speed and quality",
            "GPT-4o — Best overall quality, highest cost",
            "Gemini 2.5 Flash — Google's fast model, good for code",
            "LLaMA 3.1 8B — Open source, fast, free tier available"
          ],
          "description": "AI model to use via OpenRouter (deepseek/deepseek-chat recommended for coding)"
        },
        "voiceCodingAssistant.recordingDurationMs": {
          "type": "number",
          "default": 7000,
          "description": "Recording duration for active commands in ms (default: 7000)"
        },
        "voiceCodingAssistant.deepgramApiKey": {
          "type": "string",
          "default": "",
          "description": "Deepgram API Key (required)"
        },
        "voiceCodingAssistant.voiceFeedbackEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable text-to-speech voice feedback (spoken confirmations)"
        },
        "voiceCodingAssistant.voiceFeedbackRate": {
          "type": "number",
          "default": 5,
          "minimum": 0,
          "maximum": 10,
          "description": "Voice feedback speaking rate (0 = slow, 5 = normal, 10 = fast)"
        },
        "voiceCodingAssistant.voiceFeedbackVolume": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "Voice feedback volume (0 = silent, 100 = max)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "dev": "npm run watch & npm run lint & npm run vscode:prepublish",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./node_modules/vscode/bin/test",
    "package": "vsce package",
    "build": "npm run compile",
    "setup": "npm install"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "mocha": "^10.2.0",
    "@types/mocha": "^10.0.6",
    "@vscode/test-electron": "^2.3.8",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "dotenv": "^16.3.1",
    "node-record-lpcm16": "^1.0.1"
  }
}