{
    "compilerOptions": {
        /* The compiled JavaScript files go into the "out" folder */
        "module": "commonjs",
        /* VS Code extensions use CommonJS modules (require/module.exports) */
        "target": "ES2021",
        /* Compile to modern JavaScript that Node.js understands */
        "outDir": "out",
        /* Output directory for compiled .js files */
        "lib": [
            "ES2021"
        ],
        /* Use modern JavaScript features */
        "sourceMap": true,
        /* Create .map files for debugging (lets you debug TypeScript directly) */
        "rootDir": "src",
        /* Tell TypeScript: source files are in the "src" folder */
        "strict": true,
        /* Enable strict type checking for fewer bugs */
        "esModuleInterop": true,
        /* Better compatibility when importing npm packages */
        "skipLibCheck": true,
        /* Skip type checking of declaration files (faster compilation) */
        "forceConsistentCasingInFileNames": true,
        /* Prevent bugs from inconsistent file name casing */
        "resolveJsonModule": true
        /* Allow importing JSON files */
    },
    "exclude": [
        "node_modules",
        ".vscode-test",
        "out"
    ]
}